{
  "kind": "collectionType",
  "collectionName": "docs",
  "info": {
    "singularName": "doc",
    "pluralName": "docs",
    "displayName": "Document de la FAQ"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
