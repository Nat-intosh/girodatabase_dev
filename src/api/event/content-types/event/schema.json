{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "# Agenda"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "cover": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "name": {
      "type": "string",
      "required": true
    },
    "is_recurring_event": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "date": {
      "type": "datetime",
      "conditions": {
        "visible": {
          "!=": [
            {
              "var": "is_recurring_event"
            },
            true
          ]
        }
      },
      "required": true
    },
    "end_date": {
      "type": "datetime",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "is_recurring_event"
            },
            false
          ]
        }
      }
    },
    "recurring_day": {
      "type": "enumeration",
      "conditions": {
        "visible": {
          "!=": [
            {
              "var": "is_recurring_event"
            },
            false
          ]
        }
      },
      "enum": [
        "monday",
        "tuesday",
        "wednesday",
        "thursday",
        "friday",
        "saturday",
        "sunday"
      ]
    },
    "recurring_hour": {
      "type": "time",
      "conditions": {
        "visible": {
          "!=": [
            {
              "var": "is_recurring_event"
            },
            false
          ]
        }
      }
    },
    "place": {
      "type": "string",
      "required": true
    },
    "event_category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::event-category.event-category",
      "inversedBy": "events"
    },
    "shortdescription": {
      "type": "text",
      "required": true
    },
    "longdescription": {
      "type": "text"
    },
    "link": {
      "type": "string"
    },
    "slug": {
      "type": "uid"
    },
    "recurring_start": {
      "type": "date",
      "conditions": {
        "visible": {
          "!=": [
            {
              "var": "is_recurring_event"
            },
            false
          ]
        }
      }
    },
    "recurring_end": {
      "type": "date",
      "conditions": {
        "visible": {
          "!=": [
            {
              "var": "is_recurring_event"
            },
            false
          ]
        }
      }
    }
  }
}
